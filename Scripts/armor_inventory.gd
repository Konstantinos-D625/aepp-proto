extends "res://Scripts/equipment_catalog.gd"

## Καθολική (autoload) κατάσταση για το σύστημα πανοπλιών.
## Υποκλάση του Scripts/equipment_catalog.gd — ακριβώς η ίδια αρχιτεκτονική
## και λογική με το Scripts/weapon_inventory.gd (κατάλογος, τιμολόγηση,
## αγορά/πώληση, persistence, starter grant, στατιστικά μέσω get_item_buffs),
## γενικευμένη πλέον εκεί ώστε να μην ξαναγράφεται. Εδώ ορίζονται ΜΟΝΟ τα
## δεδομένα κάθε πανοπλίας (_configure).
##
## ΑΡΧΙΤΕΚΤΟΝΙΚΗ: κάθε εικόνα μέσα σε κάθε φάκελο κατηγορίας πανοπλίας είναι
## ένα ξεχωριστό, μοναδικά ονομασμένο, αγοράσιμο κομμάτι πανοπλίας. Σε
## αντίθεση με τα όπλα (Level1..Level9.png), οι εικόνες πανοπλίας ήρθαν ήδη
## ονομασμένες με το υλικό/στυλ τους (π.χ. "Δαιμονικό.png") αντί για αριθμό
## level — γι' αυτό εδώ το "old_level" (1-6, ίδιο πλήθος σε όλες τις
## κατηγορίες) αντιστοιχεί στην επίσημη ιεραρχία υλικού: Γήινο(1) <
## Σιδερένιο(2) < Κρυσταλικό(3) < Αγγελικό(4) < Παγωμένο(5) < Δαιμονικό(6).
## Το Βασιλικό/Βασιλικές tier (παλιό old_level 7 σε Κράνος/Μπότες) αφαιρέθηκε
## μαζί με τον ενημερωμένο φάκελο Πανοπλία — οι εικόνες του δεν υπάρχουν πια.
## Ο κανόνας "old_level × 15" (EquipmentCatalog._price_power) εφαρμόζεται
## ΜΟΝΟ για την ΤΙΜΗ ΑΓΟΡΑΣ — το ίδιο σύστημα οικονομίας με τα όπλα. Η Άμυνα
## ΔΕΝ ακολουθεί καμία φόρμουλα — είναι το χειροκίνητο "buffs" κάθε κομματιού
## στο items παρακάτω.
##
## Για να αλλάξεις τα στατιστικά μιας πανοπλίας: άλλαξε ΑΠΕΥΘΕΙΑΣ τους
## αριθμούς στο "buffs" του entry της παρακάτω (Shield/HP) — καμία φόρμουλα.
## Για να προστεθεί νέα πανοπλία στο μέλλον: αντέγραψε την εικόνα μέσα στον
## φάκελο της κατηγορίας της (Πανοπλία/<category>/<αρχείο>.png) και πρόσθεσε
## ένα {file, name, buffs} entry στο items[category] — καμία άλλη αλλαγή
## λογικής.

func _configure() -> void:
	item_dir = "res://Πανοπλία/"
	stat_label = "Άμυνα"
	stat_icon = "🛡"
	primary_stat_key = "Shield"
	# Καμία starter πανοπλία — ο παίκτης ξεκινά χωρίς εξοπλισμό, ΟΛΑ
	# αγοράζονται από το Shop (starter_ids μένει άδειο, βλ. equipment_catalog.gd).
	# Οι πανοπλίες ΔΕΝ αναβαθμίζονται (μόνο αγορά/πώληση) — η Άμυνα κάθε
	# κομματιού είναι το σταθερό "buffs" (βλ. items παρακάτω), οριστική από
	# την αγορά. Ούτε τα όπλα έχουν πλέον tiers (βλ. weapon_inventory.gd).
	upgradable = false

	# Σειρά όπως ζητήθηκε: Chest, Helmet, Pants, Boots.
	categories = ["Θώρακας", "Κράνος", "Παντελόνι", "Μπότες"]

	# Δεν δόθηκαν συγκεκριμένοι πολλαπλασιαστές κατηγορίας πανοπλίας στο
	# brief (μόνο για τα όπλα) — εφαρμόζεται η ΙΔΙΑ λογική (αύξουσα σειρά
	# από το φθηνότερο στο ακριβότερο κομμάτι), με το Θώρακα (μεγαλύτερο
	# κομμάτι, μεγαλύτερη κάλυψη) να είναι το ακριβότερο. Μόνο τιμολόγηση —
	# ΔΕΝ επηρεάζει τα stats.
	category_multiplier = {
		"Μπότες": 1.0,
		"Παντελόνι": 1.3,
		"Κράνος": 1.6,
		"Θώρακας": 2.0,
	}

	# Κάθε πανοπλία: "file" (πραγματικό όνομα αρχείου, χωρίς επέκταση, μέσα
	# στον φάκελο της κατηγορίας), "name" (fantasy όνομα), "buffs" (stats ΠΟΥ
	# ΔΙΝΕΙ ΟΤΑΝ ΕΞΟΠΛΙΣΤΕΙ — Shield + HP, χειροκίνητα ανά κομμάτι, ΚΑΜΙΑ
	# φόρμουλα). Σειρά = επίσημη ιεραρχία: Γήινο < Σιδερένιο < Κρυσταλικό <
	# Αγγελικό < Παγωμένο < Δαιμονικό (old_level 1-6, ίδια σε όλες τις
	# κατηγορίες). Κρατιέται ΕΝΑ κομμάτι (το Γήινο) ανά κατηγορία — για να
	# προστεθούν κι άλλα αργότερα, ξαναβάλε επιπλέον entries εδώ και τις
	# αντίστοιχες εικόνες στον φάκελο της κατηγορίας.
	#
	# Εξαίρεση: το "Θώρακας_2" (Bad Goblin Armor) — τρόπαιο από τον καλικάντζαρο
	# (βλ. mini_boss_popup.gd BOSS_DEFS["goblin"]["armor_reward"] +
	# boss_fight.gd::_conclude_fight, EquipmentCatalog.grant). Δεν ανήκει στην
	# υλική ιεραρχία Γήινο<Σιδερένιο<... των άλλων κατηγοριών (γι' αυτό ΜΟΝΟ ο
	# Θώρακας έχει 2ο entry) — "hidden": true = ΔΕΝ αγοράζεται/εμφανίζεται στο
	# Shop (βλ. EquipmentCatalog.is_shop_hidden/buy), παίρνεται ΜΟΝΟ νικώντας
	# τον καλικάντζαρο· μόλις αποκτηθεί, φαίνεται κανονικά στο Inventory.
	items = {
		"Θώρακας": [
			{"file": "Γήινος", "name": "Wildroot Bark Plate", "buffs": {"Shield": 3, "HP": 3}},
			{"file": "goblin_armour", "name": "Bad Goblin Armor", "buffs": {"Shield": 8, "HP": 1}, "hidden": true},
		],
		"Κράνος": [
			{"file": "Γήινο", "name": "Antlerwood Wildhelm", "buffs": {"Shield": 3, "HP": 2}},
		],
		"Παντελόνι": [
			{"file": "Γήινο", "name": "Bramblewood Legguards", "buffs": {"Shield": 3, "HP": 1}},
		],
		"Μπότες": [
			{"file": "Γήινες", "name": "Rootbound Treads", "buffs": {"Shield": 1, "HP": 2}},
		],
	}

	category_labels = {
		"Θώρακας": "Θώρακες",
		"Κράνος": "Κράνη",
		"Παντελόνι": "Παντελόνια",
		"Μπότες": "Μπότες",
	}
