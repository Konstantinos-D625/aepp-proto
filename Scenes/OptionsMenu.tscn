[gd_scene format=3 uid="uid://optionsmenu001"]

[ext_resource type="Script" uid="uid://kmjwcryfq44w" path="res://Scripts/OptionsMenu.gd" id="options_script"]

[sub_resource type="StyleBoxFlat" id="options_bg"]
